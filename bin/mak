#!/usr/bin/env bash
# MAK TUI launcher
# Resolves the project root and runs the TUI via the venv interpreter so the
# user does not need to activate the virtual environment manually.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="/Users/chaseungjun/everything/Code/multi-agent-kernel"

VENV_PYTHON="$ROOT/.venv/bin/python"
if [[ ! -x "$VENV_PYTHON" ]]; then
    echo "error: venv not found at $ROOT/.venv" >&2
    echo "       Run: python3 -m venv .venv && .venv/bin/pip install -e ." >&2
    exit 1
fi

# Run from the project root so mak/config.yaml and mak/.env resolve correctly.
cd "$ROOT"
exec "$VENV_PYTHON" -m cli "$@"
